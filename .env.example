# ── LLM ──────────────────────────────────────────────────────────────────────
# "openrouter" uses an online API (recommended). "ollama" is fully local.
LLM_PROVIDER=openrouter

# Get a FREE key at https://openrouter.ai → Sign up → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# Free models that work well (pick one):
#   meta-llama/llama-3.1-8b-instruct:free   ← recommended
#   mistralai/mistral-7b-instruct:free
#   qwen/qwen-2-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Ollama (only if LLM_PROVIDER=ollama) — install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Web Search ────────────────────────────────────────────────────────────────
# Set to false to skip web search (faster but less detailed reports)
USE_WEB_SEARCH=true

# ── LangSmith (optional — view agent traces) ──────────────────────────────────
# 1. Go to https://smith.langchain.com → sign up free
# 2. Settings → API Keys → Create API Key
# 3. Set LANGSMITH_TRACING=true and paste key below
# 4. Restart backend — traces appear at smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=startup-simulator
